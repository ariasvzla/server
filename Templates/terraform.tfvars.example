# Proxmox API Configuration
proxmox_api_url      = "https://proxmox.example.com:8006/api2/json"
proxmox_api_token_id = "root@pam!terraform"
proxmox_api_token    = "your-api-token-secret-here"
proxmox_tls_insecure = true
proxmox_debug        = false
proxmox_node         = "pve-node1"  # Your Proxmox node name

# Kubernetes Cluster Configuration
cluster_name         = "k8s-prod"
control_plane_count  = 3
worker_node_count    = 3

# VM Template
vm_template_name     = "ubuntu-22.04-template"  # Template must exist on Proxmox
base_vmid            = 100

# Control Plane Resources
control_plane_memory = 4096   # 4GB RAM
control_plane_cores  = 4      # 4 CPU cores
control_plane_disk_size = "50G"

# Worker Node Resources
worker_memory        = 4096   # 4GB RAM
worker_cores         = 4      # 4 CPU cores
worker_disk_size     = "50G"

# Network Configuration
network_bridge       = "vmbr0"
network_subnet       = "192.168.1.0/24"
gateway              = "192.168.1.1"
nameservers          = ["8.8.8.8", "8.8.4.4"]
domain               = "k8s.local"

# Storage
storage_pool         = "local-lvm"

# Cloud-init Configuration
cloud_init_user      = "ubuntu"
cloud_init_password  = ""  # Leave empty if using SSH keys
ssh_public_keys      = [
  "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIJawkMfdVXYLPsJDUfd61j+1FCkc/1cpQSLAx3m0o7t1 github"
]
ssh_private_key_path = "~/.ssh/id_ed25519"
